{
  "info": {
    "_postman_id": "6f1e7856-7ca6-457f-9515-56621abf1df4",
    "name": "DataHarbour Project (DHP) API (Local)",
    "description": "Postman collection for all local DataHarbour Project (DHP) service APIs (job, metadata, log, storage).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const saveVar = (key, value) => {",
          "  pm.collectionVariables.set(key, value);",
          "  if (pm.environment && pm.environment.name) {",
          "    pm.environment.set(key, value);",
          "  }",
          "};",
          "const existingRunId = pm.environment.get('run_id') || pm.collectionVariables.get('run_id');",
          "if (!existingRunId) {",
          "  const rid = Date.now().toString();",
          "  saveVar('run_id', rid);",
          "  saveVar('db_name', `postman_db_${rid}`);",
          "  saveVar('table_name', `postman_table_${rid}`);",
          "  saveVar('bucket_name', `postman-bucket-${rid}`);",
          "  saveVar('object_key', `postman/${rid}/sample.txt`);",
          "  saveVar('job_name', `postman_job_${rid}`);",
          "}"
        ]
      }
    }
  ],
