        {
          "name": "Submit Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_name\": \"{{job_name}}\",\n  \"job_type\": \"spark_etl\",\n  \"entrypoint\": \"{{entrypoint}}\",\n  \"arguments\": [\"--date\", \"2026-03-28\", \"--mode\", \"incremental\"],\n  \"spark_config\": {\n    \"spark.executor.memory\": \"2g\",\n    \"spark.executor.cores\": 1\n  },\n  \"database_name\": \"{{db_name}}\",\n  \"table_name\": \"{{table_name}}\",\n  \"submitted_by\": \"{{submitted_by}}\",\n  \"max_retries\": 1\n}"
            },
            "url": "{{job_service_url}}/api/v1/jobs/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 202', function () { pm.response.to.have.status(202); });",
                  "const body = pm.response.json();",
                  "pm.test('Response has job_id', function () { pm.expect(body.job_id).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('job_id', body.job_id);",
                  "if (pm.environment && pm.environment.name) { pm.environment.set('job_id', body.job_id); }"
                ]
              }
            }
          ]
        },
