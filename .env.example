# ============================================
# DataHarbour Project (DHP) - Environment Variables
# ============================================
# Copy this file to .env and adjust values as needed.
# Default values are suitable for local development.
# ============================================

# --- Database ---
POSTGRES_PASSWORD=dev-db-password-change-me

# --- Object Storage (MinIO/S3) ---
S3_ACCESS_KEY=dev-access-key-change-me
S3_SECRET_KEY=dev-secret-key-change-me

# --- API Authentication ---
API_KEY=dev-api-key-change-me
INTERNAL_API_TOKEN=dev-internal-token-change-me

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001,http://localhost:8002,http://localhost:8003,http://localhost:8004

# --- Orchestrator: Kubernetes ---
# These RUNTIME_ vars are what the Spark container sees from inside K8s.
# They resolve Docker-internal hostnames to host-reachable addresses.
K8S_HOST_ALIAS=host.docker.internal
K8S_SKIP_TLS_VERIFY=true
RUNTIME_KAFKA_BROKERS=host.docker.internal:29092
RUNTIME_JOB_SERVICE_URL=http://host.docker.internal:8001
RUNTIME_S3_ENDPOINT=http://host.docker.internal:9000
JOB_SERVICE_URL=http://job-service:8000

# --- Orchestrator: Spark Resource Limits ---
# Adjust these if Spark pods are stuck in Pending due to insufficient resources.
DEFAULT_CPU_REQUEST=250m
DEFAULT_CPU_LIMIT=1000m
DEFAULT_MEMORY_REQUEST=512Mi
DEFAULT_MEMORY_LIMIT=2Gi

# --- Orchestrator: Fluent Bit ---
ENABLE_FLUENT_BIT_SIDECAR=true
