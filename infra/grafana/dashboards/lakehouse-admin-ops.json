              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{job=\"blackbox_tcp\"}",
          "legendFormat": "{{target}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Metrics Scrape Status",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\"prometheus|loki|job-service|metadata-service|log-service|storage-service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API Request Rate (RPS) by Service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(http_requests_total{job=~\"job-service|metadata-service|log-service|storage-service\"}[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "API Error Rate (RPS) by Service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(http_requests_total{job=~\"job-service|metadata-service|log-service|storage-service\",status=~\"4xx|5xx\"}[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "P95 API Latency (s) by Service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_highr_seconds_bucket{job=~\"job-service|metadata-service|log-service|storage-service\"}[5m])))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Top Endpoints (Requests in Last 15m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-BlYlRd" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(12, sum by (job, handler, method, status) (increase(http_requests_total{job=~\"job-service|metadata-service|log-service|storage-service\"}[15m])))",
          "legendFormat": "{{job}} {{method}} {{handler}} {{status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage (cores) by Service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(process_cpu_seconds_total{job=~\"job-service|metadata-service|log-service|storage-service\"}[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory RSS (MiB) by Service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "unit", "value": "decmbytes" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{job=~\"job-service|metadata-service|log-service|storage-service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Open File Descriptors by Service",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_open_fds{job=~\"job-service|metadata-service|log-service|storage-service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Job API Activity (job-service)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(http_requests_total{job=\"job-service\",handler=\"/api/v1/jobs/\",method=\"POST\",status=\"2xx\"}[5m])",
          "legendFormat": "submissions"
        },
        {
          "refId": "B",
          "expr": "rate(http_requests_total{job=\"job-service\",handler=\"/api/v1/jobs/{job_id}/status\",method=\"PUT\",status=\"2xx\"}[5m])",
          "legendFormat": "status callbacks"
        },
        {
          "refId": "C",
          "expr": "rate(http_requests_total{job=\"job-service\",handler=\"/api/v1/jobs/{job_id}/logs\",method=\"GET\",status=\"2xx\"}[5m])",
          "legendFormat": "log fetches"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Loki Log Volume by job_id (15m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (job_id) (count_over_time({job_id=~\".+\"}[15m])))",
          "queryType": "range",
          "legendFormat": "{{job_id}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Recent ERROR Logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job_id=~\".+\"} |= \"ERROR\"",
          "queryType": "range"
        }
      ]
    }
  ],
